# Trello — read-only credentials. Copy this file to ".env.local" and fill in.
# These are SECRET: never commit .env.local, never expose to the browser.
# Get them at https://trello.com/power-ups/admin (API key) and generate a token.
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here

# Not a secret — the "Creative Tasks" board. Safe to keep here for one-home config.
TRELLO_BOARD_ID=5c781bbfe5ada150f318a677

# Shared password for the /manager leadership cockpit (fail-closed if unset).
MANAGER_PASSWORD=choose_a_shared_phrase
